<Window x:Class="AppleEsportsErp.ClientAgent.Views.LockScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apple Esports - PC Locked"
        WindowState="Maximized"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="False"
        Background="#0D0D1A"
        Icon="/Assets/logo.ico">

    <Window.Resources>
        <!-- Glow animation for the logo circle -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GlowEllipse"
                           Storyboard.TargetProperty="Opacity"
                           From="0.3" To="0.8" Duration="0:0:2"
                           AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0D1A" Offset="0"/>
                <GradientStop Color="#1A0A2E" Offset="0.5"/>
                <GradientStop Color="#0D0D1A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Center content -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- Animated glow circle behind logo -->
            <Grid Width="200" Height="200" Margin="0,0,0,30">
                <Ellipse x:Name="GlowEllipse" Width="200" Height="200" Opacity="0.3">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#6C3CE0" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Logo image -->
                <Image Source="pack://application:,,,/Assets/logo.png" Width="100" Height="100"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <!-- Title -->
            <TextBlock Text="APPLE ESPORTS" 
                      FontSize="42" FontWeight="Bold" Foreground="White"
                      HorizontalAlignment="Center" Margin="0,0,0,10"
                      FontFamily="Segoe UI">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#6C3CE0" BlurRadius="20" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>

            <!-- Lock message -->
            <TextBlock Text="This PC is locked" 
                      FontSize="24" Foreground="#B0B0C0"
                      HorizontalAlignment="Center" Margin="0,0,0,5"
                      FontFamily="Segoe UI Light"/>

            <TextBlock Text="Please see the operator to start a session" 
                      FontSize="16" Foreground="#707088"
                      HorizontalAlignment="Center" Margin="0,0,0,40"
                      FontFamily="Segoe UI Light"/>

            <!-- Connection status indicator -->
            <Border Background="#1A1A2E" CornerRadius="20" Padding="20,10" 
                    HorizontalAlignment="Center" BorderBrush="#2A2A4E" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10" 
                            Fill="#00FF88" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Connected — LAN Mode" 
                              FontSize="14" Foreground="#A0A0B8" VerticalAlignment="Center"
                              FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- PC Number -->
            <TextBlock x:Name="PcNumberText" Text="PC-1" 
                      FontSize="14" Foreground="#505068"
                      HorizontalAlignment="Center" Margin="0,20,0,0"
                      FontFamily="Segoe UI"/>

            <!-- Timer (shown during active session countdown) -->
            <TextBlock x:Name="TimerText" Text="" 
                      FontSize="48" FontWeight="Bold" Foreground="#FFD700"
                      HorizontalAlignment="Center" Margin="0,30,0,0"
                      FontFamily="Segoe UI" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Bottom bar -->
        <TextBlock Text="© Apple Esports ERP — Gaming PC Agent v1.0" 
                  FontSize="11" Foreground="#303048"
                  HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                  Margin="0,0,0,20" FontFamily="Segoe UI"/>
    </Grid>
</Window>
