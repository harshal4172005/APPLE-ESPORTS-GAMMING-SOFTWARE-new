# Copy this file to .env and fill in real values before running docker-compose.
# Never commit the real .env — it's gitignored on purpose.
#   cp .env.example .env

# ── Database ──
DB_NAME=gamecafe_erp
DB_USER=gamecafe_admin
DB_PASSWORD=change_this_to_a_strong_password

# ── Redis ──
REDIS_PASSWORD=change_this_to_a_strong_password

# ── JWT (must each be at least 32 random characters, and DIFFERENT from each other) ──
JWT_SECRET=change_this_to_a_random_32plus_char_string
JWT_REFRESH_SECRET=change_this_to_a_different_random_32plus_char_string

# ── Email (SMTP) — used for password resets and admin notifications ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
