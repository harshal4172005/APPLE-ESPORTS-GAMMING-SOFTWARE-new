# APPLE ESPORTS GAMING SOFTWARE
# Environment Variables Template
# Copy this file to `.env` and fill in the secrets before starting the system.

# ==========================================
# Database Configuration
# ==========================================
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_DATABASE_PASSWORD
DB_NAME=gamecafe_erp

# ==========================================
# JWT Secrets
# ==========================================
# MUST BE AT LEAST 32 CHARACTERS LONG!
JWT_SECRET=YOUR_SECURE_JWT_SECRET_KEY_MIN_32_CHARS
JWT_REFRESH_SECRET=YOUR_SECURE_JWT_REFRESH_KEY_MIN_32_CHARS

# ==========================================
# Redis Configuration (Optional Backplane)
# ==========================================
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD

# ==========================================
# Email / SMTP Configuration
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=YOUR_SMTP_APP_PASSWORD
SMTP_FROM_EMAIL=your_email@gmail.com
